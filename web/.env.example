# Google OAuth Client ID
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Google Maps API Key (Places API & Maps JavaScript API must be enabled)
VITE_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# ─── Blog auto-generation (scripts/generate-blog.js) ───────────────────────
# Anthropic Claude API key
ANTHROPIC_API_KEY=sk-ant-...

# Amazon affiliate links (set after registering at associates.amazon.co.jp)
AFFILIATE_AMAZON_MAIN=https://www.amazon.co.jp/your-paddle-link
AFFILIATE_AMAZON_SUB=https://www.amazon.co.jp/your-set-link
